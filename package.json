{
  "name": "finops-mcp-server",
  "version": "3.0.0",
  "description": "Cloud FinOps Analyst MCP Server - AI-powered AWS cost analysis",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./tools": {
      "import": "./dist/tools/index.js",
      "require": "./dist/tools/index.js",
      "types": "./src/tools/index.ts"
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "finops",
    "aws",
    "cost-optimization",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1065.0",
    "@aws-sdk/client-cost-explorer": "^3.1065.0",
    "@aws-sdk/client-ec2": "^3.1065.0",
    "@aws-sdk/client-rds": "^3.1065.0",
    "@aws-sdk/client-resource-groups-tagging-api": "^3.1065.0",
    "@azure/arm-compute": "^24.0.0",
    "@azure/arm-costmanagement": "^1.0.0-beta.1",
    "@azure/arm-monitor": "^7.0.0",
    "@azure/arm-mysql-flexible": "^3.1.0",
    "@azure/arm-postgresql-flexible": "^9.0.0",
    "@azure/arm-sql": "^10.0.0",
    "@azure/identity": "^4.13.1",
    "@google-cloud/bigquery": "^8.3.1",
    "@google-cloud/compute": "^6.13.0",
    "@google-cloud/monitoring": "^5.3.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
